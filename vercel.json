{
  "redirects": [
    { "source": "/about-us", "destination": "/about", "permanent": true },
    { "source": "/about-us/", "destination": "/about", "permanent": true },
    { "source": "/about-us-old", "destination": "/about", "permanent": true },
    { "source": "/about-us-old/", "destination": "/about", "permanent": true },
    { "source": "/data-direct", "destination": "/work/datadirect", "permanent": true },
    { "source": "/data-direct/", "destination": "/work/datadirect", "permanent": true },
    { "source": "/sealac", "destination": "/work", "permanent": true },
    { "source": "/sealac/", "destination": "/work", "permanent": true },
    { "source": "/man-tissues", "destination": "/work", "permanent": true },
    { "source": "/man-tissues/", "destination": "/work", "permanent": true },
    { "source": "/eddie-jordan-foundation", "destination": "/work", "permanent": true },
    { "source": "/eddie-jordan-foundation/", "destination": "/work", "permanent": true },
    { "source": "/mindful", "destination": "/work", "permanent": true },
    { "source": "/mindful/", "destination": "/work", "permanent": true },
    { "source": "/luvit", "destination": "/work", "permanent": true },
    { "source": "/luvit/", "destination": "/work", "permanent": true },
    { "source": "/blogs", "destination": "/blog", "permanent": true },
    { "source": "/blogs/", "destination": "/blog", "permanent": true },
    { "source": "/2025/:path*", "destination": "/blog", "permanent": true },
    { "source": "/2026/:path*", "destination": "/blog", "permanent": true },
    { "source": "/contact-old", "destination": "/contact", "permanent": true },
    { "source": "/contact-old/", "destination": "/contact", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
